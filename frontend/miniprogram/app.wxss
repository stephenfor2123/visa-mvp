/* app.wxss - 全局样式(对齐 web 端 design tokens) */
page {
  --primary: #3B6EF5;
  --primary-hover: #2D5BFF;
  --primary-light: #EAF0FE;
  --ink-1: #1A1D29;
  --ink-2: #5A5F6D;
  --ink-3: #9CA3AF;
  --muted: #9CA3AF;
  --bg: #FAFBFC;
  --bg-alt: #F1F4F8;
  --surface: #FFFFFF;
  --line: #E5E7EB;
  --border: #E5E7EB;
  --success: #10B981;
  --warning: #F59E0B;
  --danger: #DC2626;
  --warn-bg: #FFFBEB;
  --warn-border: #FCD34D;
  --warn-text: #92400E;

  background: var(--bg);
  color: var(--ink-1);
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", Helvetica, Arial, sans-serif;
  font-size: 28rpx;  /* 14px on 750rpx design */
  line-height: 1.5;
}

view, text, button, input { box-sizing: border-box; }

.container {
  padding: 24rpx;
  min-height: 100vh;
}

.card {
  background: var(--surface);
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 1rpx 4rpx rgba(15,23,42,.04);
}

.text-primary { color: var(--primary); }
.text-danger  { color: var(--danger); }
.text-muted   { color: var(--ink-3); }
.text-success { color: var(--success); }

.text-h1 { font-size: 48rpx; font-weight: 700; line-height: 1.3; }
.text-h2 { font-size: 36rpx; font-weight: 600; line-height: 1.3; }
.text-h3 { font-size: 32rpx; font-weight: 600; }
.text-sub { font-size: 26rpx; color: var(--ink-3); }

.divider {
  height: 1rpx;
  background: var(--border);
  margin: 16rpx 0;
}

/* 通用按钮基础 (AppButton 组件使用) */
.btn-base {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  font-weight: 500;
  border: none;
  cursor: pointer;
  transition: opacity .15s;
}
.btn-base[disabled] { opacity: 0.5; pointer-events: none; }

.btn-primary { background: var(--primary); color: #fff; }
.btn-outline { background: transparent; color: var(--primary); border: 2rpx solid var(--primary); }
.btn-ghost   { background: var(--bg-alt); color: var(--ink-2); }

.btn-sm { padding: 12rpx 24rpx; font-size: 24rpx; }
.btn-md { padding: 18rpx 32rpx; font-size: 28rpx; }
.btn-lg { padding: 24rpx 32rpx; font-size: 32rpx; width: 100%; }

/* 输入框基础 (AppInput 组件使用) */
.input-row {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-bottom: 24rpx;
}
.input-label {
  font-size: 26rpx;
  color: var(--ink-2);
  font-weight: 500;
}
.input-field {
  background: var(--bg-alt);
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: var(--ink-1);
  border: 2rpx solid transparent;
}
.input-field:focus {
  border-color: var(--primary);
  background: #fff;
}
.input-error {
  font-size: 24rpx;
  color: var(--danger);
  margin-top: 4rpx;
}
.input-hint {
  font-size: 24rpx;
  color: var(--ink-3);
  margin-top: 4rpx;
}
