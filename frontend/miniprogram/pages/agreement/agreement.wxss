/* pages/agreement/agreement.wxss */
.page-agreement { display: flex; flex-direction: column; height: 100vh; background: #FAFBFC; }
.header { padding: 32rpx 32rpx 16rpx; }
.header .title { display: block; font-size: 40rpx; font-weight: 700; color: #111827; }
.header .subtitle { display: block; font-size: 24rpx; color: #6B7280; margin-top: 8rpx; }
.tabs { display: flex; padding: 0 24rpx; border-bottom: 2rpx solid #E5E7EB; }
.tab { flex: 1; padding: 24rpx 0; text-align: center; font-size: 28rpx; color: #6B7280; font-weight: 600; position: relative; }
.tab-active { color: #3B6EF5; }
.tab-active::after { content: ''; position: absolute; bottom: -2rpx; left: 50%; transform: translateX(-50%); width: 60rpx; height: 6rpx; background: linear-gradient(135deg, #3B6EF5, #5B86F7); border-radius: 3rpx; }
.content { flex: 1; padding: 24rpx 32rpx 40rpx; }
.doc-head { padding: 24rpx 0; border-bottom: 1rpx solid #E5E7EB; margin-bottom: 24rpx; }
.doc-title { display: block; font-size: 36rpx; font-weight: 700; color: #111827; }
.doc-meta { display: block; font-size: 24rpx; color: #6B7280; margin-top: 8rpx; }
.section { margin-bottom: 32rpx; }
.section-title { display: block; font-size: 30rpx; font-weight: 700; color: #111827; margin-bottom: 12rpx; }
.section-body { display: block; font-size: 28rpx; line-height: 1.7; color: #374151; }
