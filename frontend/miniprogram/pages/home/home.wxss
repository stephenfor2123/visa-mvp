/* pages/home/home.wxss */
.page-home {
  min-height: 100vh;
  background: var(--bg, #FAFBFC);
  padding: 24rpx;
}
.hero {
  background: linear-gradient(135deg, #3B6EF5 0%, #6E59F0 100%);
  color: #fff;
  border-radius: 24rpx;
  padding: 48rpx 32rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(59, 110, 245, .25);
}
.hero__title {
  font-size: 48rpx; font-weight: 700; margin-bottom: 12rpx; line-height: 1.2;
}
.hero__sub {
  font-size: 26rpx; opacity: .9; margin-bottom: 32rpx; line-height: 1.5;
}
.hero__cta {
  display: flex; gap: 16rpx; margin-bottom: 32rpx;
}
.hero__cta .app-button:nth-child(1) {
  background: #fff; color: var(--primary, #3B6EF5);
}
.hero__cta .app-button:nth-child(2) {
  background: transparent; color: #fff; border: 2rpx solid rgba(255, 255, 255, .6);
}
.hero__chips {
  display: flex; flex-wrap: wrap; gap: 12rpx;
}
.hero__chip {
  background: rgba(255, 255, 255, .15);
  border: 2rpx solid rgba(255, 255, 255, .2);
  border-radius: 16rpx;
  padding: 16rpx 20rpx;
  display: flex; flex-direction: column; gap: 4rpx;
  min-width: 180rpx;
}
.hero__chip .flag { font-size: 32rpx; }
.hero__chip .name { font-weight: 600; font-size: 26rpx; }
.hero__chip .meta { opacity: .8; font-size: 20rpx; }

.features { padding: 0 8rpx; }
.section-title {
  font-size: 36rpx; font-weight: 700; color: var(--ink-1, #1A1D29); margin-bottom: 8rpx;
}
.section-sub {
  font-size: 26rpx; color: var(--ink-2, #5A5F6D); margin-bottom: 24rpx;
}
.features__grid {
  display: flex; flex-direction: column; gap: 20rpx;
}
.feature {
  background: var(--surface, #fff);
  border: 2rpx solid var(--line, #E5E7EB);
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
}
.feature__title {
  font-size: 30rpx; font-weight: 600; color: var(--ink-1, #1A1D29); margin-bottom: 8rpx;
}
.feature__desc {
  font-size: 26rpx; color: var(--ink-2, #5A5F6D); line-height: 1.6;
}
