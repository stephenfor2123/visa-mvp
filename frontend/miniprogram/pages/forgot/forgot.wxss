/* pages/forgot/forgot.wxss */
.page-forgot { min-height: 100vh; background: #FAFBFC; padding: 32rpx 32rpx 60rpx; }
.header { margin-bottom: 40rpx; }
.header .title { display: block; font-size: 44rpx; font-weight: 700; color: #111827; }
.header .subtitle { display: block; font-size: 26rpx; color: #6B7280; margin-top: 12rpx; }
.form-row { margin-bottom: 32rpx; }
.form-label { display: block; font-size: 28rpx; font-weight: 600; color: #374151; margin-bottom: 12rpx; }
.form-input-row { display: flex; align-items: center; background: #FFFFFF; border-radius: 16rpx; border: 2rpx solid #E5E7EB; overflow: hidden; }
.form-input { flex: 1; padding: 24rpx 24rpx; font-size: 30rpx; background: #FFFFFF; }
.form-input-row .form-input { border: none; }
.country-picker { display: flex; align-items: center; padding: 24rpx 20rpx; border-right: 2rpx solid #E5E7EB; font-size: 28rpx; color: #374151; }
.country-picker .caret { margin-left: 8rpx; color: #9CA3AF; font-size: 22rpx; }
.btn-sms { padding: 16rpx 24rpx; background: linear-gradient(135deg, #3B6EF5, #5B86F7); color: #FFFFFF; font-size: 26rpx; font-weight: 600; border-radius: 12rpx; margin: 8rpx 8rpx 8rpx 0; white-space: nowrap; }
.btn-sms-disabled { background: #D1D5DB; color: #6B7280; }
.form-err { display: block; font-size: 24rpx; color: #DC2626; margin-top: 8rpx; }
.btn-primary { display: block; width: 100%; padding: 28rpx 0; background: linear-gradient(135deg, #3B6EF5, #5B86F7); color: #FFFFFF; border-radius: 16rpx; font-size: 32rpx; font-weight: 700; text-align: center; margin-top: 48rpx; }
.btn-primary-loading { opacity: 0.6; }
.link-back { display: block; text-align: center; margin-top: 24rpx; font-size: 26rpx; color: #3B6EF5; }
.success { padding: 200rpx 48rpx 0; text-align: center; display: flex; flex-direction: column; align-items: center; }
.success-icon { font-size: 120rpx; }
.success-title { display: block; font-size: 40rpx; font-weight: 700; color: #111827; margin-top: 32rpx; }
.success-desc { display: block; font-size: 28rpx; color: #6B7280; margin-top: 16rpx; margin-bottom: 48rpx; }
.success .btn-primary { margin-top: 0; }
