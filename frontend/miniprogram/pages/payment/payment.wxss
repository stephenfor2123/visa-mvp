/* pages/payment/payment.wxss */
.page-payment { min-height: 100vh; background: #FAFBFC; display: flex; flex-direction: column; }
.header { padding: 32rpx 32rpx 24rpx; text-align: center; }
.header .title { display: block; font-size: 40rpx; font-weight: 700; color: #111827; }
.header .subtitle { display: block; font-size: 24rpx; color: #6B7280; margin-top: 8rpx; }
.loading { padding: 200rpx 0; text-align: center; }
.loading-icon { display: block; font-size: 80rpx; }
.loading-text { display: block; font-size: 28rpx; color: #6B7280; margin-top: 24rpx; }
.body { flex: 1; padding: 0 24rpx; }
.info-card { background: #FFFFFF; border-radius: 24rpx; padding: 28rpx 32rpx; margin-bottom: 24rpx; box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04); }
.info-row { display: flex; justify-content: space-between; align-items: center; padding: 12rpx 0; }
.info-label { font-size: 26rpx; color: #6B7280; }
.info-value { font-size: 28rpx; color: #111827; font-weight: 600; }
.info-value.amount { color: #3B6EF5; font-size: 36rpx; font-weight: 700; }
.qr-card { background: #FFFFFF; border-radius: 24rpx; padding: 48rpx 32rpx; margin-bottom: 24rpx; box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04); text-align: center; }
.qr-frame { width: 360rpx; height: 360rpx; margin: 0 auto; background: #F9FAFB; border: 4rpx dashed #3B6EF5; border-radius: 16rpx; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 16rpx; }
.qr-emoji { font-size: 80rpx; }
.qr-code-text { font-size: 20rpx; color: #6B7280; margin-top: 16rpx; word-break: break-all; text-align: center; }
.qr-hint { display: block; font-size: 28rpx; color: #111827; font-weight: 600; margin-top: 32rpx; }
.status-card { display: flex; align-items: center; padding: 24rpx 32rpx; border-radius: 16rpx; margin-bottom: 16rpx; }
.status-pending { background: #FEF3C7; color: #92400E; }
.status-paid { background: #D1FAE5; color: #065F46; }
.status-failed { background: #FEE2E2; color: #991B1B; }
.status-icon { font-size: 40rpx; margin-right: 16rpx; }
.status-text { font-size: 28rpx; font-weight: 600; }
.poll-bar { display: flex; justify-content: space-between; align-items: center; padding: 16rpx 0; font-size: 26rpx; color: #6B7280; }
.btn-link { color: #3B6EF5; font-size: 26rpx; font-weight: 600; }
.debug { margin-top: 16rpx; padding: 16rpx 20rpx; background: #F3F4F6; border-radius: 8rpx; }
.debug-line { display: block; font-size: 20rpx; color: #6B7280; font-family: monospace; word-break: break-all; }
.footer { padding: 24rpx 24rpx 40rpx; }
.btn-secondary { width: 100%; text-align: center; padding: 24rpx 0; background: #FFFFFF; color: #3B6EF5; border: 2rpx solid #3B6EF5; border-radius: 16rpx; font-size: 30rpx; font-weight: 600; }
