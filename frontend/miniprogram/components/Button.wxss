/* components/Button.wxss */
.btn-base {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  font-weight: 500;
  border: none;
  cursor: pointer;
  transition: opacity .15s;
  line-height: 1.2;
}
.btn-base[disabled] { opacity: 0.5; }
.btn-hover { opacity: 0.85; }
.btn-block { display: flex; width: 100%; }

.btn-primary { background: var(--primary, #3B6EF5); color: #fff; }
.btn-outline { background: transparent; color: var(--primary, #3B6EF5); border: 2rpx solid var(--primary, #3B6EF5); }
.btn-ghost   { background: var(--bg-alt, #F1F4F8); color: var(--ink-2, #5A5F6D); }

.btn-sm { padding: 12rpx 24rpx; font-size: 24rpx; }
.btn-md { padding: 18rpx 32rpx; font-size: 28rpx; }
.btn-lg { padding: 24rpx 32rpx; font-size: 32rpx; width: 100%; display: flex; }

.btn-spinner {
  width: 24rpx;
  height: 24rpx;
  border: 3rpx solid currentColor;
  border-top-color: transparent;
  border-radius: 50%;
  margin-right: 8rpx;
  animation: btn-spin 0.8s linear infinite;
}
@keyframes btn-spin {
  to { transform: rotate(360deg); }
}
