/* components/Card.wxss */
.card-shell {
  background: var(--surface, #FFFFFF);
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 1rpx 4rpx rgba(15, 23, 42, .04);
  border: 1rpx solid var(--line, #E5E7EB);
}
.card-hoverable {
  transition: all .15s;
}
.card-hoverable:active {
  transform: scale(0.99);
  box-shadow: 0 2rpx 8rpx rgba(15, 23, 42, .08);
}
.card-header {
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid var(--border, #E5E7EB);
}
.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--ink-1, #1A1D29);
}
.card-body { /* 内容容器,无 padding */ }
.card-footer {
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--border, #E5E7EB);
}
