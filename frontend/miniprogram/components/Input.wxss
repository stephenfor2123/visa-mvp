/* components/Input.wxss */
.input-row {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-bottom: 24rpx;
}
.input-label {
  font-size: 26rpx;
  color: var(--ink-2, #5A5F6D);
  font-weight: 500;
}
.input-wrap {
  display: flex;
  align-items: center;
  background: var(--bg-alt, #F1F4F8);
  border-radius: 12rpx;
  padding: 0 24rpx;
  border: 2rpx solid transparent;
  min-height: 80rpx;
}
.input-wrap.has-error {
  border-color: var(--danger, #DC2626);
}
.input-field {
  flex: 1;
  background: transparent;
  font-size: 28rpx;
  color: var(--ink-1, #1A1D29);
  padding: 20rpx 0;
  min-height: 80rpx;
}
.input-placeholder {
  color: var(--ink-3, #9CA3AF);
  font-size: 28rpx;
}
.input-error {
  font-size: 24rpx;
  color: var(--danger, #DC2626);
  margin-top: 4rpx;
}
.input-hint {
  font-size: 24rpx;
  color: var(--ink-3, #9CA3AF);
  margin-top: 4rpx;
}
