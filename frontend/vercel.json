{
  "buildCommand": "cd web && npm run build",
  "outputDirectory": "web/dist",
  "installCommand": "cd web && npm install",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://api.htexvisa.com/api/:path*"
    },
    { "source": "/((?!api/|robots\\.txt|sitemap\\.xml|llms\\.txt|llms-full\\.txt|ai-index\\.json|feed\\.xml|favicon\\.svg|manifest\\.json|icons/|en/visa-guides/|vi/visa-guides/|id/visa-guides/|zh-cn/visa-guides/|[A-Za-z0-9_-]+\\.txt).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
