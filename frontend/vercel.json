{
  "buildCommand": "cd web && npm run build",
  "outputDirectory": "web/dist",
  "installCommand": "cd web && npm install",
  "framework": "vite",
  "rewrites": [
    { "source": "/((?!robots\\.txt|sitemap\\.xml|llms\\.txt|llms-full\\.txt|favicon\\.svg|manifest\\.json|icons/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
