# 复制为 .env 后按需修改
# 是否走 mock(后端未就绪时用 mock 兜底,真实联调改成 false)
# W1 已对接 B 后端,默认 false 走真实 API
VITE_MOCK=false

# 后端 API 地址
# 开发环境用 vite proxy 转发 → /api/v2/*
# 生产环境改为真实域名,例如 https://api.visa-mvp.com
VITE_API_BASE=/api

# 应用环境
VITE_APP_ENV=development

# WebSocket host (用于 /ws/orders/{no} 实时订单状态推送)
# 默认 ws://localhost:8000 走 vite 转发;生产改为 wss://your-domain
VITE_WS_URL=ws://localhost:8000