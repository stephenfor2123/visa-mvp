# 复制为 .env 后按需修改
# 是否走 mock(后端未就绪时用 mock 兜底,真实联调改成 false)
# W1 已对接 B 后端,默认 false 走真实 API
VITE_MOCK=false

# 后端 API 地址
# 开发环境用 vite proxy 转发 → /api/v2/*
# 生产环境改为真实域名,例如 https://api.visa-mvp.com
VITE_API_BASE=/api

# 应用环境
VITE_APP_ENV=development

# WebSocket host (用于 /ws/orders/{no} 实时订单状态推送)
# 默认 ws://localhost:8000 走 vite 转发;生产改为 wss://your-domain
VITE_WS_URL=ws://localhost:8000

# --- Product scope ---
# 客户市场: 越南+印尼海外用户; 办理目的地: 美/申根/英/澳等(不变)
# 微信小程序暂不维护
VITE_FEATURE_RPA=false
VITE_FEATURE_INSURANCE=false

# 在 https://console.cloud.google.com/apis/credentials 创建 OAuth 2.0 Client ID
#   Application type: Web application
#   Authorized JavaScript origins:
#     http://localhost:5173          (dev)
#     https://visa.example.com       (prod — 按你的真实域名改)
#   Authorized redirect URIs: 同上
# 留空时 /login 不显示 Google 按钮(纯密码登录);填上后立即生效。
# E2E 测试 global-setup.cjs 会注入一个 fake 值让 placeholder 渲染,不需要真 client id。
# 生产(Vercel): .env* 不进 git,必须在 Vercel → Project → Settings → Environment Variables
#   添加 VITE_GOOGLE_CLIENT_ID(Production),然后 Redeploy。缺此变量时线上按钮会消失。
VITE_GOOGLE_CLIENT_ID=

# Stripe 公钥 (仅 stripe 通道需要,对应后端 STRIPE_PUBLISHABLE_KEY)
# 留空时前端从 GET /api/v2/payment/config 读取
VITE_STRIPE_PUBLISHABLE_KEY=