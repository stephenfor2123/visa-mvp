{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/((?!robots\\.txt|sitemap\\.xml|llms\\.txt|llms-full\\.txt|ai-index\\.json|feed\\.xml|favicon\\.svg|manifest\\.json|icons/|en/visa-guides/|vi/visa-guides/|id/visa-guides/|zh-cn/visa-guides/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
