# --- App ---
APP_NAME="Visa MVP API"
APP_VERSION="0.1.0"
ENV=dev
DEBUG=1
API_PREFIX=/api/v2
HOST=0.0.0.0
PORT=8000

# --- Database ---
# SQLite default for dev. Swap to Postgres in prod.
DATABASE_URL=sqlite+aiosqlite:///./data/visa_mvp.db
DB_ECHO=0

# --- JWT ---
# IMPORTANT: change this in production. >= 32 bytes recommended.
JWT_SECRET=dev-secret-change-me-in-prod-visa-mvp-2026
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_MINUTES=120
REFRESH_TOKEN_TTL_DAYS=7

# --- Password policy (V2 §4.1.4) ---
BCRYPT_COST=12
PASSWORD_MIN_LENGTH=8
PASSWORD_MAX_LENGTH=32

# --- SMS (V2 §4.1.5) ---
# mock / twilio / aliyun
SMS_CHANNEL=mock
SMS_CODE_TTL_SECONDS=300
SMS_COOLDOWN_SECONDS=60
SMS_DAILY_LIMIT=10
SMS_LOG_DIR=./logs
# Optional: dev-only callback URL (V2 §4.1.4 "Webhook 模式")
MOCK_SMS_WEBHOOK_URL=

# --- Rate limit (V2 §9.4) ---
RATE_LIMIT_PER_IP_PER_MIN=100
RATE_LIMIT_SLOW_API_PER_IP_PER_MIN=60

# --- Celery / Redis ---
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# --- RAG auto-refresh (signature policy update) ---
# Off by default — hits real government visa websites, so opt in per env.
RAG_AUTO_REFRESH_ENABLED=0
RAG_AUTO_REFRESH_INTERVAL_HOURS=168

# --- Logging ---
LOG_DIR=./logs
LOG_LEVEL=INFO

# --- Stripe (V2 §4.5 — V2.1 阶段) ---
# V2 本地 dev/test 走 MockPaymentProvider, Stripe 字段留空即可运行.
# V2.1 真接步骤:
#   1. 登录 https://dashboard.stripe.com/test/apikeys 获取 sk_test_xxx
#   2. 填入 STRIPE_SECRET_KEY (sk_test_xxx 格式)
#   3. 在 Stripe Dashboard 创建 webhook, 填 whsec_xxx 到 STRIPE_WEBHOOK_SECRET
#   4. Affiliate payout: 在 Connect 页面创建 account, 填 acct_xxx 到 STRIPE_PAYOUT_ACCOUNT_ID
#
# 安全: 禁止提交真实 key. 推荐 macOS 钥匙串:
#   security add-generic-password -s visa-mvp-stripe -a STRIPE_SECRET_KEY -w 'sk_test_xxx'
#   然后 launcher 从钥匙串读入 process env (见 config.py docstring).
#
# STRIPE_SECRET_KEY=sk_test_your_real_key_here
# STRIPE_PUBLISHABLE_KEY=pk_test_your_real_publishable_key_here
# STRIPE_WEBHOOK_SECRET=whsec_your_real_webhook_secret_here
# STRIPE_PAYOUT_ACCOUNT_ID=acct_your_real_connect_account_here

# 支付通道: mock (默认,零凭据) | stripe (需 STRIPE_SECRET_KEY)
# PAYMENT_CHANNEL=mock

# --- Product scope ---
# 客户市场: 越南+印尼海外用户(Web); 办理目的地: 美/申根/英/澳等(不变)
# FEATURE_RPA_ENABLED=0          # RPA 自动递交 — 后期再开
# FEATURE_INSURANCE_ENABLED=0    # 拒签险 — 后期再开

# 后端 POST /api/v2/auth/google 接收 Google id_token,用 GOOGLE_CLIENT_ID 验签。
# 留空时端点返回 SERVER_ERROR(预期);前端 VITE_GOOGLE_CLIENT_ID 也留空时按钮隐藏。
# 申请步骤:
#   1. 登录 https://console.cloud.google.com/apis/credentials
#   2. 创建 OAuth 2.0 Client ID → Application type: Web application
#   3. Authorized JavaScript origins:
#        http://localhost:5173          (dev)
#        https://visa.example.com       (prod)
#   4. 把 .apps.googleusercontent.com 后缀的 client id 填到下面(也填到 frontend/web/.env 的 VITE_GOOGLE_CLIENT_ID)
# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# --- WeChat miniprogram login (V2 §4.1) ---
# WECHAT_APPID=
# WECHAT_APPSECRET=

# --- Privacy / compliance ---
# 隐私/Data Subject 请求联系邮箱 (公开于 GET /api/v2/auth/public-config)
PRIVACY_SUPPORT_EMAIL=privacy@htex.app
# 密码重置/邮箱验证链接前缀 (prod 必改)
APP_FRONTEND_BASE=http://localhost:5173

# --- Email / Resend (registration verification codes) ---
# RESEND_API_KEY=re_xxx   # prod: htex-email-prod key (Sending access, htexvisa.com)
# EMAIL_FROM=HTEX <noreply@htexvisa.com>
# EMAIL_CODE_TTL_SECONDS=600
# EMAIL_COOLDOWN_SECONDS=60
# EMAIL_DAILY_LIMIT=10
