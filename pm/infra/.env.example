# pm/infra/.env.example
# 复制到 backend/.env 后填实际值
# 启动 ngrok/cloudflared 时会自动追加/更新 PUBLIC_BASE_URL

# ===== 后端基础 =====
APP_ENV=development
APP_DEBUG=true
APP_PORT=8000

# ===== 数据库 =====
DATABASE_URL=sqlite+aiosqlite:///./data/visa_mvp.db

# ===== JWT =====
JWT_SECRET=change-me-in-production-min-32-chars-please-do-it
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MIN=30
JWT_REFRESH_TTL_DAY=14

# ===== SMS(V2 阶段 mock,任意 6 位数字通过) =====
SMS_MODE=mock
SMS_MOCK_ALLOW_ALL=true

# ===== 支付(V2 阶段 disable) =====
PAYMENT_MODE=mock
PAYMENT_TOTAL_AMOUNT_DEFAULT=0

# ===== CORS =====
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# ===== 公共(ngrok / cloudflared 自动填) =====
# PUBLIC_BASE_URL=https://xxxx.trycloudflare.com
