{
  "manifest_version": 3,
  "name": "Htex — DS-160 辅助填充",
  "version": "0.2.0",
  "description": "把 Htex 订单的 12 位 code 兑换成档案，自动辅助填入 DS-160 官网。数据只在你本地，不经服务器。",
  "permissions": ["storage", "scripting", "activeTab"],
  "host_permissions": [
    "https://ceac.state.gov/*",
    "https://*.ustraveldocs.com/*",
    "https://*.usvisa-info.com/*",
    "https://api.htexvisa.com/*",
    "http://localhost:8000/*"
  ],
  "background": { "service_worker": "src/background.js" },
  "action": { "default_popup": "popup.html", "default_title": "Htex DS-160" },
  "content_scripts": [
    {
      "matches": ["https://ceac.state.gov/genniv/*"],
      "js": ["src/mapping.js", "src/fillEngine.js", "src/journey.js", "src/wayfinder.js", "src/content-ds160.js", "src/content-journey.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://*.ustraveldocs.com/*", "https://*.usvisa-info.com/*"],
      "js": ["src/journey.js", "src/wayfinder.js", "src/content-journey.js"],
      "run_at": "document_idle"
    }
  ]
}